# The Leverage Stack — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# ─── VoiceBox (local TTS server) ─────────────────────────────────────────────
VOICEOVER_ENGINE=voicebox
VOICEBOX_HOST=127.0.0.1
VOICEBOX_PORT=17493
VOICEBOX_PROFILE_NAME=LeverageVoice
VOICEBOX_ENGINE_TYPE=qwen
VOICEBOX_MODEL=1.7B

# ─── Meta Graph API (Instagram + Facebook) ───────────────────────────────────
META_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id
FACEBOOK_PAGE_ID=your_facebook_page_id

# ─── TikTok Content Posting API ──────────────────────────────────────────────
# Get from developers.tiktok.com → My Apps → your app → Auth
TIKTOK_ACCESS_TOKEN=your_tiktok_user_access_token
TIKTOK_OPEN_ID=your_tiktok_open_id

# ─── Cloudflare R2 (video hosting — all platforms pull from this URL) ─────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_token_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_token_secret_access_key
R2_BUCKET_NAME=leverage-stack
VIDEO_PUBLIC_URL_BASE=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev/leverage-stack

# ─── FFmpeg ───────────────────────────────────────────────────────────────────
FFMPEG_BIN=C:/Users/jesse/Documents/ffmpeg/bin/ffmpeg.exe

# ─── Affiliate Links (direct program links — used as fallback over ClickBank) ─
AFFILIATE_ELEVENLABS_LINK=your_elevenlabs_affiliate_link
AFFILIATE_WRITESONIC_LINK=your_writesonic_affiliate_link
AFFILIATE_KOALA_LINK=your_koala_affiliate_link

# ─── ClickBank ────────────────────────────────────────────────────────────────
# Get from accounts.clickbank.com → Settings → API Keys
CLICKBANK_DEV_KEY=your_clickbank_developer_key
CLICKBANK_CLERK_KEY=your_clickbank_clerk_key
CLICKBANK_NICKNAME=your_clickbank_affiliate_nickname
